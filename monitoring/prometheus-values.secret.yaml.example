# Copier ce fichier en `monitoring/prometheus-values.secret.yaml` (gitignoré,
# voir .gitignore) et y mettre le vrai webhook Slack avant l'install :
#
#   cp monitoring/prometheus-values.secret.yaml.example monitoring/prometheus-values.secret.yaml
#   # éditer l'URL ci-dessous avec le vrai webhook
#   helm install monitoring prometheus-community/kube-prometheus-stack \
#     -n monitoring --create-namespace \
#     -f monitoring/prometheus-values.yaml \
#     -f monitoring/prometheus-values.secret.yaml
#
# Ne JAMAIS commit le fichier prometheus-values.secret.yaml lui-même.

alertmanager:
  config:
    receivers:
      - name: slack
        slack_configs:
          - api_url: "https://hooks.slack.com/services/T000/B000/XXXXXXXXXXXXXXXXXXXXXXXX"
            channel: "#capstone-cdm2026"
            send_resolved: true
